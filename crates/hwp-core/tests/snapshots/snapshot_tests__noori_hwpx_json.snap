            },
            {
              "char_shape_id": 39,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "발사체 개발에 직접 참여"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 36,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "하고 있는 연구자, 산업체 관계자 약"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 41,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "400명의 선호도 조사를 통해 최종 선정"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 42,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "하는 절차로 진행되었다."
                      }
                    ]
                  }
                }
              ]
            }
          ],
          "line_segments": [
            {
              "text_start_pos": 0,
              "vertical_pos": 9656,
              "line_height": 1500,
              "text_height": 1500,
              "baseline_distance": 1275,
              "line_spacing": 1052,
              "column_start_pos": 0,
              "segment_width": 48188,
              "flags": 393216
            },
            {
              "text_start_pos": 38,
              "vertical_pos": 12208,
              "line_height": 1500,
              "text_height": 1500,
              "baseline_distance": 1275,
              "line_spacing": 1052,
              "column_start_pos": 0,
              "segment_width": 48188,
              "flags": 1441792
            }
          ],
          "has_char_shapes": true
        },
        {
          "id": 0,
          "para_shape_id": 39,
          "style_id": 0,
          "page_break": false,
          "column_break": false,
          "merged": false,
          "para_tc_id": null,
          "meta_tag": null,
          "runs": [
            {
              "char_shape_id": 36,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "□ 이러한"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 46,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "절차를 거쳐 한국형발사체의"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 45,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "새로운 명칭은 ‘누리’로 결정"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 46,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "되"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 44,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "었으며, 동 명칭은 앞으로 우리나라 독자 발사체인"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 49,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "‘한국형발사체’의"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 39,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "공식 명칭으로 사용"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 36,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "될 예정이다."
                      }
                    ]
                  }
                }
              ]
            }
          ],
          "line_segments": [
            {
              "text_start_pos": 0,
              "vertical_pos": 16060,
              "line_height": 1500,
              "text_height": 1500,
              "baseline_distance": 1275,
              "line_spacing": 1052,
              "column_start_pos": 0,
              "segment_width": 48188,
              "flags": 393216
            },
            {
              "text_start_pos": 37,
              "vertical_pos": 18612,
              "line_height": 1500,
              "text_height": 1500,
              "baseline_distance": 1275,
              "line_spacing": 1052,
              "column_start_pos": 0,
              "segment_width": 48188,
              "flags": 1441792
            },
            {
              "text_start_pos": 76,
              "vertical_pos": 21164,
              "line_height": 1500,
              "text_height": 1500,
              "baseline_distance": 1275,
              "line_spacing": 1052,
              "column_start_pos": 0,
              "segment_width": 48188,
              "flags": 1441792
            }
          ],
          "has_char_shapes": true
        },
        {
          "id": 0,
          "para_shape_id": 40,
          "style_id": 0,
          "page_break": false,
          "column_break": false,
          "merged": false,
          "para_tc_id": null,
          "meta_tag": null,
          "runs": [
            {
              "char_shape_id": 36,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "o 동 명칭을 제출한 경상대학교 에너지기계공학과 백승엽 학생은"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 44,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "‘"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 49,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "누리’는 ‘세상’의 옛말"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 44,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "로"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 49,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "우주로까지 확장된 새로운 세상을"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 55,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "연다는"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 45,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": []
                  }
                }
              ]
            },
            {
              "char_shape_id": 38,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "의미"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 37,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "로, 우리 손으로 만든 발사체로 온 우주를 누비고 미래"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 42,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "발전을"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 36,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "누리길 희망하는 마음을 담았다고 밝혔다."
                      }
                    ]
                  }
                }
              ]
            }
          ],
          "line_segments": [
            {
              "text_start_pos": 0,
              "vertical_pos": 24716,
              "line_height": 1500,
              "text_height": 1500,
              "baseline_distance": 1275,
              "line_spacing": 1052,
              "column_start_pos": 0,
              "segment_width": 48188,
              "flags": 393216
            },
            {
              "text_start_pos": 37,
