        {
          "id": 0,
          "para_shape_id": 36,
          "style_id": 0,
          "page_break": false,
          "column_break": false,
          "merged": false,
          "para_tc_id": null,
          "meta_tag": null,
          "runs": [
            {
              "char_shape_id": 36,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "o"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 46,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "백승엽학생에게는 오는 9월 7일(금)에 과기정통부 장관상과 함께 소정의"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 36,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "상금이 수여될 예정이다."
                      }
                    ]
                  }
                }
              ]
            }
          ],
          "line_segments": [
            {
              "text_start_pos": 0,
              "vertical_pos": 35924,
              "line_height": 1500,
              "text_height": 1500,
              "baseline_distance": 1275,
              "line_spacing": 1052,
              "column_start_pos": 0,
              "segment_width": 48188,
              "flags": 393216
            },
            {
              "text_start_pos": 40,
              "vertical_pos": 38476,
              "line_height": 1500,
              "text_height": 1500,
              "baseline_distance": 1275,
              "line_spacing": 1052,
              "column_start_pos": 0,
              "segment_width": 48188,
              "flags": 1441792
            }
          ],
          "has_char_shapes": true
        },
        {
          "id": 0,
          "para_shape_id": 33,
          "style_id": 0,
          "page_break": false,
          "column_break": false,
          "merged": false,
          "para_tc_id": null,
          "meta_tag": null,
          "runs": [
            {
              "char_shape_id": 36,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "□"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 47,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "과기정통부 거대공공연구정책관은 “명칭 공모전을 통해 우리국민의"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 39,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "우주에 대한 높은 관심을 확인"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 36,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "할 수 있었다”며 “새로운 이름에 걸맞게 무한한 가능성을 갖고 있는"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 39,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "우주공간을 우리 발사체로 직접 개척할 수 있도록 최선을 다할 것"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 36,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "” 이라고 밝혔다."
                      }
                    ]
                  }
                }
              ]
            }
          ],
          "line_segments": [
            {
              "text_start_pos": 0,
              "vertical_pos": 42328,
