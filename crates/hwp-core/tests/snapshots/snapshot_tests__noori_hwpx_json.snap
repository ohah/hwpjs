                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 40,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "그간 별도의 명칭 없이 ‘한국형발사체’라 불려온 우리 발사체의 새로"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 36,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "운 이름을 선정하기 위해"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 39,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "대국민 명칭 공모전을 실시"
