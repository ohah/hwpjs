                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 42,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "참여하여 2021년 발사를 목표로 개발하고 있다"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 36,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "."
