                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "□ 과기정통부는 한국항공우주연구원"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 33,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "(원장 임철호, 이하 ‘항우연’)"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "char_shape_id": 36,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "과 함께"
