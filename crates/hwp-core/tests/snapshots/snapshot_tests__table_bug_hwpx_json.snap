                                              "elements": [
                                                {
                                                  "Text": "본인은 대덕소프트웨어마이스터고등학교 (시설)(예: 유치원, 어린이집, 아동복지시설, 청소년쉼터, 청소년활동시설, 의료기관 등) 취업자"
                                                }
                                              ]
                                            }
                                          }
                                        ]
                                      },
                                      {
                                        "char_shape_id": 45,
                                        "contents": [
                                          {
                                            "Text": {
                                              "char_shape_id": null,
                                              "elements": [
                                                {
                                                  "Text": "(취업예정자)로서, 「아동ㆍ청소년의 성보호에 관한 법률」 제56조 및 같은 법 시행령 제25조에 따른 성범죄경력"
                                                }
                                              ]
                                            }
                                          }
                                        ]
                                      },
                                      {
                                        "char_shape_id": 41,
                                        "contents": [
                                          {
                                            "Text": {
                                              "char_shape_id": null,
                                              "elements": [
                                                {
                                                  "Text": " 조회,"
                                                }
                                              ]
                                            }
                                          }
                                        ]
                                      },
                                      {
                                        "char_shape_id": 24,
                                        "contents": [
                                          {
                                            "Text": {
                                              "char_shape_id": null,
                                              "elements": [
                                                {
                                                  "Text": "「"
                                                }
                                              ]
                                            }
                                          }
                                        ]
                                      },
                                      {
                                        "char_shape_id": 25,
                                        "contents": [
                                          {
                                            "Text": {
                                              "char_shape_id": null,
                                              "elements": [
                                                {
                                                  "Text": "아동복지법」 제29조의3에 "
                                                }
                                              ]
                                            }
                                          }
                                        ]
                                      },
                                      {
                                        "char_shape_id": 24,
                                        "contents": [
                                          {
                                            "Text": {
                                              "char_shape_id": null,
                                              "elements": [
                                                {
                                                  "Text": "따른 아동학대 범죄전력 조회 신청에 동의"
                                                }
                                              ]
                                            }
                                          }
                                        ]
                                      },
                                      {
                                        "char_shape_id": 41,
                                        "contents": [
                                          {
                                            "Text": {
                                              "char_shape_id": null,
                                              "elements": [
                                                {
                                                  "Text": "합니다."
                                                }
                                              ]
                                            }
                                          }
                                        ]
                                      }
                                    ],
                                    "line_segments": [
                                      {
                                        "text_start_pos": 0,
