          "para_shape_id": 0,
          "style_id": 0,
          "page_break": false,
          "column_break": false,
          "merged": false,
          "para_tc_id": null,
          "meta_tag": null,
          "runs": [
            {
              "char_shape_id": 0,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "2) 종류 - <묶은 가로 막대형>으로 작업할 것"
                      }
                    ]
                  }
                }
              ]
            }
          ],
          "line_segments": [
            {
              "text_start_pos": 0,
              "vertical_pos": 11200,
              "line_height": 1000,
              "text_height": 1000,
