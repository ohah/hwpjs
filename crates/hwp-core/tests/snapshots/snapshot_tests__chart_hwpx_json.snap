          "runs": [
            {
              "char_shape_id": 0,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "1) 차트 데이터는 표 내용에서 연도별 초등학교, 중학교, 고등학교의 값만 이용할 것"
                      }
                    ]
                  }
                }
              ]
            }
          ],
          "line_segments": [
            {
              "text_start_pos": 0,
              "vertical_pos": 35627,
              "line_height": 1000,
              "text_height": 1000,
              "baseline_distance": 850,
              "line_spacing": 600,
              "column_start_pos": 0,
              "segment_width": 53292,
              "flags": 393216
            }
          ],
          "has_char_shapes": true
        },
        {
          "id": 2147483648,
          "para_shape_id": 0,
          "style_id": 0,
          "page_break": false,
          "column_break": false,
          "merged": false,
          "para_tc_id": null,
          "meta_tag": null,
          "runs": [
            {
              "char_shape_id": 0,
              "contents": [
                {
                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "2) 종류 - <묶은 세로 막대형>으로 작업할 것"
                      }
                    ]
                  }
                }
              ]
            }
          ],
          "line_segments": [
            {
              "text_start_pos": 0,
              "vertical_pos": 37227,
              "line_height": 1000,
