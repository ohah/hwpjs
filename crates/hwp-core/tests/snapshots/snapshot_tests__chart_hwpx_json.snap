                    "elements": [
                      {
                        "Text": "<<차트조건>>"
                      }
                    ]
                  }
                }
              ]
            }
          ],
          "line_segments": [
            {
              "text_start_pos": 0,
              "vertical_pos": 34027,
              "line_height": 1000,
              "text_height": 1000,
              "baseline_distance": 850,
              "line_spacing": 600,
              "column_start_pos": 0,
              "segment_width": 53292,
              "flags": 393216
            }
          ],
          "has_char_shapes": true
        },
        {
          "id": 2147483648,
          "para_shape_id": 0,
          "style_id": 0,
          "page_break": false,
