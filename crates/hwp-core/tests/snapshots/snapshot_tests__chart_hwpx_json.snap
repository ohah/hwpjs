                  "Text": {
                    "char_shape_id": null,
                    "elements": [
                      {
                        "Text": "3) 제목 – 굴림, 진하게, 12pt, 배경 – 선 모양(한줄로), 그림자(2pt)"
                      }
                    ]
                  }
                }
              ]
            }
          ],
          "line_segments": [
